AWS_REGION=ap-south-1

# DynamoDB Tables
USERS_TABLE=UsersTable
RESUMES_TABLE=ResumesTable
SESSIONS_TABLE=SessionsTable
TRANSCRIPTS_TABLE=TranscriptsTable
FEEDBACK_TABLE=FeedbackTable
CONCEPT_STATES_TABLE=ConceptStatesTable
WS_CONNECTIONS_TABLE=WSConnectionsTable
NOTIFICATIONS_TABLE=NotificationsTable

# S3 Buckets
RESUMES_BUCKET=ResumesBucket
SCRAPED_CONTENT_BUCKET=ScrapedContentBucket

# SNS Topic
FEEDBACK_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:qlue-feedback-trigger

# API Gateway Endpoints
WEBSOCKET_ENDPOINT=https://your-api-id.execute-api.ap-south-1.amazonaws.com/prod/

# Bedrock & Polly Configuration
BEDROCK_MODEL_ID=amazon.nemotron-4-340b-instruct
POLLY_VOICE_ID=Joanna

# CORS Origin
CORS_ORIGIN=*

# Logging
LOG_LEVEL=DEBUG

# LOCAL MOCK SECRETS (Do not push real secrets to your .env)
# These represent secrets normally loaded via Secrets Manager but you can
# emulate behavior or map them locally if modifying the utility wrapper for testing.
MOCK_FIREBASE_SERVICE_ACCOUNT={}
MOCK_BEDROCK_CONFIG={}
MOCK_SCRAPER_API_KEY=your_mock_scraper_do_api_key
MOCK_FCM_SERVER_KEY=your_mock_fcm_key
